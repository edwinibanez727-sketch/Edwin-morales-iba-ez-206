Algoritmo Promedio 
	definir CAL1, CAL2, CAL3  Como Entero
	definir PROM Como Real
	
	escribir "ingresa tu primera calificasion"
	leer CAL1
	
	escribir "ingresa tu segunda calificasion" 
	leer CAL2
	
	escribir "ingresa tu tercera calificasion" 
	leer CAL3
	
	PROM=(CAL1+CAL2+CAL3)/3
	
	escribir"el resultado es:",PROM 
	      
FinAlgoritmo
